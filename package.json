{
  "name": "stockinvestor",
  "version": "1.0.0",
  "private": true,
  "description": "Electron stock profit statistics tool",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "node electron/ensure-electron-dist.cjs",
    "prestart": "node electron/ensure-electron-dist.cjs",
    "predev": "node electron/ensure-electron-dist.cjs",
    "start": "set ELECTRON_RUN_AS_NODE=&& set ELECTRON_OVERRIDE_DIST_PATH=node_modules\\electron\\dist-fixed&& electron . --disable-gpu --disable-software-rasterizer --no-sandbox --disable-gpu-compositing --disable-direct-composition --disable-accelerated-2d-canvas --use-angle=swiftshader --disable-features=RendererCodeIntegrity,CalculateNativeWinOcclusion",
    "dev": "set ELECTRON_RUN_AS_NODE=&& set ELECTRON_OVERRIDE_DIST_PATH=node_modules\\electron\\dist-fixed&& electron . --disable-gpu --disable-software-rasterizer --no-sandbox --disable-gpu-compositing --disable-direct-composition --disable-accelerated-2d-canvas --use-angle=swiftshader --disable-features=RendererCodeIntegrity,CalculateNativeWinOcclusion",
    "dist": "electron-builder"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.stockinvestor.app",
    "productName": "StockInvestor",
    "asar": true,
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "StockInvestor-${version}.exe"
    }
  }
}
